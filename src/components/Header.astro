---
---

<header class="site-header">
  <a class="brand-link" href="/" aria-label="Scott Gerstl | Home">
    <img class="brand-img" src="/wordmark.svg" alt="Scott Gerstl" />
  </a>
  <span class="tagline">Enterprise Design · AI Products · Berlin</span>
  <nav class="nav">
    <a href="/#section-ai">Cases</a>
    <a href="/lab">Lab</a>
    <a href="/resume">Resume</a>
    <a href="/#case-about">About</a>
    <a href="/#case-contact">Contact</a>
  </nav>
</header>

<script>
  import { smoothScrollTo } from '../lib/scroll';

  const HEADER_OFFSET = 80;

  let controller: AbortController | null = null;

  function scrollToHash(hash: string) {
    if (!hash || hash === '#') return false;
    let el: Element | null = null;
    try {
      el = document.querySelector(hash);
    } catch {
      return false;
    }
    if (!el) return false;
    const r = (el as HTMLElement).getBoundingClientRect();
    smoothScrollTo(window.scrollY + r.top - HEADER_OFFSET);
    return true;
  }

  function init() {
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    document.querySelectorAll<HTMLAnchorElement>('.site-header .nav a').forEach((a) => {
      a.addEventListener(
        'click',
        (e) => {
          const url = new URL(a.href, location.href);
          if (url.origin !== location.origin) return;
          if (!url.hash) return;
          if (url.pathname !== location.pathname) return;
          e.preventDefault();
          history.replaceState(null, '', url.pathname + url.hash);
          scrollToHash(url.hash);
        },
        { signal },
      );
    });

    const brand = document.querySelector<HTMLAnchorElement>('.site-header .brand-link');
    if (brand) {
      brand.addEventListener(
        'click',
        (e) => {
          if (e.metaKey || e.ctrlKey || e.shiftKey) return;
          const url = new URL(brand.href, location.href);
          if (url.pathname !== location.pathname) return;
          e.preventDefault();
          if (location.hash) history.replaceState(null, '', location.pathname);
          smoothScrollTo(0);
        },
        { signal },
      );
    }

    if (location.hash) {
      const hash = location.hash;
      window.scrollTo(0, 0);
      requestAnimationFrame(() => requestAnimationFrame(() => scrollToHash(hash)));
    }
  }

  document.addEventListener('astro:page-load', init);
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: rgba(246, 246, 246, 0.55);
    backdrop-filter: blur(18px) saturate(170%);
    -webkit-backdrop-filter: blur(18px) saturate(170%);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    z-index: 100;
    display: flex;
    align-items: center;
    padding: 0 32px;
    gap: 32px;
  }

  .brand-link {
    display: block;
    transition: opacity 0.15s ease;
  }

  .brand-link:hover {
    opacity: 0.7;
  }

  .brand-img {
    height: 44px;
    width: auto;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  .tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 13px;
    color: var(--color-text-soft);
    letter-spacing: 0.01em;
    margin-left: 8px;
  }

  .nav {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .nav a {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: opacity 0.15s ease;
  }

  .nav a:hover {
    opacity: 0.6;
  }

  @media (max-width: 767px) {
    .site-header {
      padding: 0 16px;
      gap: 12px;
    }

    .brand-img {
      height: 32px;
    }

    .tagline {
      display: none;
    }

    .nav {
      gap: 14px;
    }

    .nav a {
      font-size: 12px;
    }
  }
</style>
