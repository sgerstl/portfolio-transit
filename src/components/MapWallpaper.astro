<img class="map-background" src="/map-wallpaper.svg" alt="" aria-hidden="true" />

<style>
  .map-background {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1440px;
    height: auto;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
    filter: saturate(0.30) opacity(0.45);
  }

  /* Mobile: drop the saturate() filter and use the plain opacity property
     instead. CSS filters force per-pixel compositing on every scroll frame
     and Firefox Android is particularly bad at it; opacity composites on
     the GPU for free. The map looks slightly more colorful on mobile than
     desktop, but at 45% over a light bg the difference is minor. */
  @media (max-width: 767px) {
    .map-background {
      filter: none;
      opacity: 0.45;
    }
  }
</style>
