<img class="map-background" src="/map-wallpaper.svg" alt="" aria-hidden="true" />

<style>
  .map-background {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1440px;
    height: auto;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
    filter: saturate(0.30) opacity(0.45);
  }

  /* Hidden on mobile — a 1440px-wide fixed-position SVG with a CSS filter
     is the most expensive paint on the page, and Firefox Android is
     particularly bad at compositing filtered fixed layers during scroll.
     The map is decorative; mobile loses nothing structural without it. */
  @media (max-width: 767px) {
    .map-background {
      display: none;
    }
  }
</style>
