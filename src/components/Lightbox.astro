---
---

<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
  <button class="lightbox-close" type="button" aria-label="Close">
    <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <div class="lightbox-stage">
    <img class="lightbox-img" alt="" draggable="false" />
    <div class="lightbox-meta">
      <h3 class="lightbox-title"></h3>
      <p class="lightbox-subtitle"></p>
    </div>
  </div>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 0;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease;
  }

  .lightbox-close:hover {
    color: white;
  }

  .lightbox-stage {
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 78vh;
    object-fit: contain;
    border-radius: 4px;
    user-select: none;
    -webkit-user-drag: none;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
  }

  .lightbox-meta {
    text-align: center;
  }

  .lightbox-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: white;
    text-transform: uppercase;
  }

  .lightbox-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 4px;
  }

  @media (max-width: 767px) {
    .lightbox {
      padding: 16px;
    }

    .lightbox-close {
      top: 12px;
      right: 12px;
    }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  if (lb) {
    const img = lb.querySelector('.lightbox-img') as HTMLImageElement;
    const title = lb.querySelector('.lightbox-title') as HTMLElement;
    const subtitle = lb.querySelector('.lightbox-subtitle') as HTMLElement;
    const closeBtn = lb.querySelector('.lightbox-close') as HTMLElement;

    const open = (src: string, t: string, s: string) => {
      img.src = src;
      img.alt = t;
      title.textContent = t;
      subtitle.textContent = s;
      lb.classList.add('is-open');
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      lb.classList.remove('is-open');
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement)?.closest('[data-lightbox-src]') as HTMLElement | null;
      if (!trigger) return;
      const src = trigger.getAttribute('data-lightbox-src') || '';
      const t = trigger.getAttribute('data-lightbox-title') || '';
      const s = trigger.getAttribute('data-lightbox-subtitle') || '';
      if (src) open(src, t, s);
    });

    closeBtn.addEventListener('click', close);

    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lb.classList.contains('is-open')) close();
    });
  }
</script>
