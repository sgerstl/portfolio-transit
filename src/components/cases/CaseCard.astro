---
import type { LineKey, CaseSlug, CaseBody, PersonalBody } from '../../data/cases';

interface Props {
  slug: CaseSlug;
  name: string;
  tagline: string;
  line: LineKey;
  body?: CaseBody;
  personal?: PersonalBody;
}

const { slug, name, tagline, line, body, personal } = Astro.props;
const colorVar = `var(--color-line-${line})`;
const hasBody = !!body;
const isPersonal = !!personal;
---

<article
  class:list={['case-card', isPersonal && 'case-card--personal']}
  data-case={slug}
  id={`case-${slug}`}
  style={`--card-color: ${colorVar};`}
>
  <div class="chip"></div>
  <div class="case-header">
    <div class="case-header-text">
      <h3 class="case-name">{name}</h3>
      <p class="case-tagline">{tagline}</p>
    </div>
    {hasBody && (
      <button class="case-toggle" aria-label="Toggle case study" type="button">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    )}
  </div>
  {body && (
    <div class="case-body">
      <div class="case-body-inner">
        <div class="case-domains">
          {body.domains.map((d) => <span>{d}</span>)}
        </div>
        <p class="case-outcome">{body.outcome}</p>
        <div class="case-visual">{body.visualLabel}</div>
        <div class="case-metrics">
          {body.metrics.map((m) => (
            <div class="case-metric">
              <div class="case-metric-num">{m.num}</div>
              <div class="case-metric-label">
                {m.label}
                {m.linkHref && m.linkText && (
                  <> <a class="case-metric-link" href={m.linkHref} target="_blank" rel="noopener noreferrer">{m.linkText}</a></>
                )}
              </div>
            </div>
          ))}
        </div>
        <p class="case-claim">{body.claim}</p>
        <a class="case-cta" href={body.ctaHref}>Read the full case study →</a>
      </div>
    </div>
  )}

  {personal && (
    <div class="personal-body">
      {personal.paragraphs?.map((p) => <p>{p}</p>)}
      {personal.gallery && (
        <>
          <div class="gallery">
            {personal.gallery.slice(0, 3).map((piece) => (
              <button
                class="gallery-tile"
                type="button"
                data-lightbox-src={piece.src}
                data-lightbox-title={piece.title}
                data-lightbox-subtitle={piece.subtitle}
                aria-label={`Open ${piece.title}`}
              >
                <img src={piece.src} alt={piece.title} loading="lazy" draggable="false" />
                <div class="gallery-overlay">
                  <span class="gallery-title">{piece.title}</span>
                </div>
              </button>
            ))}
          </div>
          {personal.gallery.length > 3 && (
            <details class="gallery-more">
              <summary>
                <span class="gallery-more-label more">View more ↓</span>
                <span class="gallery-more-label less">Show less ↑</span>
              </summary>
              <div class="gallery gallery--extra">
                {personal.gallery.slice(3).map((piece) => (
                  <button
                    class="gallery-tile"
                    type="button"
                    data-lightbox-src={piece.src}
                    data-lightbox-title={piece.title}
                    data-lightbox-subtitle={piece.subtitle}
                    aria-label={`Open ${piece.title}`}
                  >
                    <img src={piece.src} alt={piece.title} loading="lazy" draggable="false" />
                    <div class="gallery-overlay">
                      <span class="gallery-title">{piece.title}</span>
                    </div>
                  </button>
                ))}
              </div>
            </details>
          )}
        </>
      )}
      {personal.links && (
        <div class="contact-links">
          {personal.links.map((link) => (
            <a
              class="contact-link"
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              <span class="contact-icon">
                {link.icon === 'email' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path>
                    <rect x="2" y="9" width="4" height="12"></rect>
                    <circle cx="4" cy="4" r="2"></circle>
                  </svg>
                )}
              </span>
              <span class="contact-text">
                <span class="contact-text-label">{link.label}</span>
                <span class="contact-text-value">{link.value}</span>
              </span>
            </a>
          ))}
        </div>
      )}
    </div>
  )}
</article>

<style>
  .case-card {
    position: relative;
    background: white;
    border-radius: 4px;
    box-shadow: 1px 2px 8px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }

  .chip {
    position: absolute;
    top: 0;
    left: 0;
    width: 9px;
    height: 100%;
    background: var(--card-color);
    transition: width 0.2s ease;
  }

  .case-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 20px 12px 28px;
    min-height: 64px;
  }

  .case-header-text {
    flex: 1;
    min-width: 0;
  }

  .case-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.0;
    color: var(--color-text);
    letter-spacing: 0.01em;
    margin-bottom: 4px;
  }

  .case-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-text);
    opacity: 0.85;
  }

  .case-toggle {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.15);
    color: var(--color-text);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.25s ease, background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    padding: 0;
  }

  .case-toggle svg {
    width: 14px;
    height: 14px;
    transition: transform 0.25s ease;
  }

  .case-card:hover {
    box-shadow: 2px 4px 14px rgba(0, 0, 0, 0.14);
    transform: translateY(-2px);
  }

  .case-card:hover .chip {
    width: 14px;
  }

  .case-card:hover .case-toggle {
    background: var(--card-color);
    border-color: var(--card-color);
    color: white;
  }

  .case-card.case-card--open .case-toggle svg {
    transform: rotate(180deg);
  }
  .case-card.case-card--open .chip {
    width: 14px;
  }

  .case-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0.0, 0.2, 1);
  }

  .case-body-inner {
    padding: 8px 28px 28px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    margin-top: 4px;
  }

  .case-domains {
    background: #FFCC00;
    margin: 0 -28px 20px;
    padding: 5px 20px 5px 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .case-domains span:not(:last-child)::after {
    content: '·';
    margin-left: 12px;
    opacity: 0.6;
  }

  .case-outcome {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-text);
    margin-bottom: 18px;
  }

  .case-visual {
    height: 220px;
    background: linear-gradient(135deg, #ececec, #f6f6f6);
    border: 1px dashed rgba(0, 0, 0, 0.18);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    margin-bottom: 22px;
  }

  .case-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 22px;
  }

  .case-metric {
    background: #f0f0f0;
    border-radius: 4px;
    padding: 14px 16px;
  }

  .case-metric-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    color: var(--card-color);
    margin-bottom: 4px;
  }

  .case-metric-label {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-text);
  }

  .case-metric-link {
    color: var(--card-color);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.15s ease;
  }

  .case-metric-link:hover {
    opacity: 0.7;
  }

  .case-claim {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.5;
    color: var(--color-text);
    margin-bottom: 18px;
  }

  .case-cta {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--card-color);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: opacity 0.15s ease;
  }

  .case-cta:hover {
    opacity: 0.7;
  }

  /* Always-expanded About + Contact bodies (no toggle, no animation). */
  .case-card--personal {
    cursor: default;
  }

  .case-card--personal:hover {
    box-shadow: 1px 2px 8px rgba(0, 0, 0, 0.08);
    transform: none;
  }

  .case-card--personal:hover .chip {
    width: 9px;
  }

  .personal-body {
    padding: 4px 28px 26px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    margin-top: 4px;
  }

  .personal-body p {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text);
    margin-top: 16px;
  }

  .gallery {
    margin-top: 16px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .gallery-tile {
    position: relative;
    padding: 0;
    margin: 0;
    border: 0;
    background: #eee;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 4 / 3;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .gallery-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
    transition: transform 0.35s ease;
  }

  .gallery-tile:hover {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.14);
  }

  .gallery-tile:hover img {
    transform: scale(1.04);
  }

  .gallery-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 8px 10px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .gallery-tile:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-title {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: white;
    letter-spacing: 0.01em;
  }

  .gallery-more {
    margin-top: 8px;
  }

  .gallery-more summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    margin-top: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-rail-blue);
    border-radius: 4px;
    transition: background 0.15s ease;
  }

  .gallery-more summary::-webkit-details-marker { display: none; }

  .gallery-more summary:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .gallery-more[open] .gallery-more-label.more { display: none; }
  .gallery-more:not([open]) .gallery-more-label.less { display: none; }

  .gallery--extra {
    margin-top: 8px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 14px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    background: #f0f0f0;
    border-radius: 4px;
    color: var(--color-text);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .contact-link:hover {
    background: #e6e6e6;
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--card-color);
    color: white;
    flex-shrink: 0;
  }

  .contact-icon svg {
    width: 18px;
    height: 18px;
  }

  .contact-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .contact-text-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-soft);
  }

  .contact-text-value {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .case-body {
      transition-duration: 0.001ms !important;
    }
    .case-toggle,
    .case-toggle svg {
      transition-duration: 0.001ms !important;
    }
  }

  @media (max-width: 767px) {
    .case-header {
      padding: 12px 16px 12px 25px;
      gap: 10px;
      min-height: 56px;
    }

    .case-name {
      font-size: 22px;
    }

    .case-tagline {
      font-size: 12px;
    }

    .case-toggle {
      width: 36px;
      height: 36px;
    }

    .case-toggle svg {
      width: 16px;
      height: 16px;
    }

    /* Asymmetric left padding so content centers between the right
       edge of the 9px chip (at card_left + 9) and the right card edge,
       not against the card's literal left edge. */
    .case-body-inner {
      padding: 6px 16px 18px 25px;
    }

    .case-domains {
      margin: 0 -16px 16px -25px;
      padding: 5px 14px 5px 25px;
      font-size: 10.5px;
      gap: 8px;
    }

    .case-outcome {
      font-size: 14px;
      line-height: 1.55;
      margin-bottom: 14px;
    }

    .case-visual {
      height: 160px;
      margin-bottom: 18px;
    }

    .case-metrics {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-bottom: 18px;
    }

    .case-metric {
      padding: 12px 14px;
    }

    .case-metric-num {
      font-size: 24px;
    }

    .case-claim {
      font-size: 14px;
      line-height: 1.5;
      margin-bottom: 18px;
    }

    /* Mobile CTA: full-width button instead of inline link */
    .case-cta {
      display: block;
      text-align: center;
      padding: 12px 16px;
      background: var(--card-color);
      color: white;
      border-radius: 4px;
      font-size: 14px;
    }

    .case-cta:hover {
      opacity: 0.9;
    }

    .personal-body {
      padding: 4px 16px 20px 25px;
    }

    .personal-body p {
      font-size: 14px;
      margin-top: 14px;
    }

    .contact-link {
      padding: 10px 12px;
      gap: 12px;
    }

    .contact-icon {
      width: 32px;
      height: 32px;
    }

    .contact-icon svg {
      width: 16px;
      height: 16px;
    }

    .contact-text-value {
      font-size: 13px;
    }
  }

  @media (max-width: 479px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: 6px;
    }
  }
</style>
