---
import type { LineKey } from '../../data/cases';

interface Props {
  line: LineKey;
}

const { line } = Astro.props;
---

<div class={`section section-${line}`} data-section={line}>
  <slot />
</div>

<style>
  .section {
    position: relative;
    z-index: 2;
    padding: 0 96px;
  }

  .section-ai {
    padding-left: 200px;
  }

  .section-ent {
    margin-top: 80px;
    padding-left: 280px;
  }

  .section-pers {
    margin-top: 80px;
    padding-left: 360px;
    padding-bottom: 80px;
  }

  /* Mid-width: drop the staircase. All sections align to the same
     padding-left so cards have maximum room without falling off the
     right edge. Rail (spine SVG) shifts left here too — see
     global.css for the --rail-center-x override. Keep padding-left
     just right of that rail center so branches travel down-and-right. */
  @media (max-width: 1199px) and (min-width: 768px) {
    .section {
      padding: 0 32px;
    }

    .section-ai,
    .section-ent,
    .section-pers {
      padding-left: 96px;
    }

    .section-ent,
    .section-pers {
      margin-top: 56px;
    }
  }

  @media (max-width: 767px) {
    .section,
    .section-ai,
    .section-ent,
    .section-pers {
      padding: 0;
      margin: 0;
    }

    /* Breathing room above each non-first section so the section
       header is clearly separated from the previous section's last
       case card. The colored bar (::before) runs through this padding
       so the line stays continuous; only the color changes. */
    .section-ent,
    .section-pers {
      padding-top: 28px;
    }

    /* Per-section colored bar on the left edge. Card chips at left:0
       overlap the bar (same color); gaps between cards expose the bar. */
    .section-ai::before,
    .section-ent::before,
    .section-pers::before {
      content: '';
      position: absolute;
      left: 16px;
      top: 0;
      bottom: 0;
      width: 9px;
      z-index: 0;
    }
    .section-ai::before  { background: var(--color-line-ai); }
    .section-ent::before { background: var(--color-line-ent); }
    .section-pers::before { background: var(--color-line-pers); }
  }
</style>
