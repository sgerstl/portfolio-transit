---
---

<script>
  import { smoothScrollTo } from '../../lib/scroll';

  const TRANSITION_MS = 420;

  let controller: AbortController | null = null;
  let currentCards: HTMLElement[] = [];

  function tickSpineDuring(durationMs: number) {
    const start = performance.now();
    function tick(now: number) {
      window.dispatchEvent(new Event('spine:redraw'));
      if (now - start < durationMs) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function openCard(card: HTMLElement) {
    currentCards.forEach((other) => {
      if (other !== card && other.classList.contains('case-card--open')) {
        closeCard(other);
      }
    });
    card.classList.add('case-card--open');
    const body = card.querySelector<HTMLElement>('.case-body');
    if (!body) return;
    body.style.maxHeight = body.scrollHeight + 'px';

    const onEnd = (e: TransitionEvent) => {
      if (e.propertyName !== 'max-height') return;
      body.style.maxHeight = 'none';
      body.removeEventListener('transitionend', onEnd);
      window.dispatchEvent(new Event('spine:redraw'));
      const cardRect = card.getBoundingClientRect();
      smoothScrollTo(window.scrollY + cardRect.top - 80);
    };
    body.addEventListener('transitionend', onEnd);

    tickSpineDuring(TRANSITION_MS);
  }

  function closeCard(card: HTMLElement) {
    const body = card.querySelector<HTMLElement>('.case-body');
    if (!body) return;
    body.style.maxHeight = body.scrollHeight + 'px';
    void body.offsetHeight;
    body.style.maxHeight = '0px';
    card.classList.remove('case-card--open');
    tickSpineDuring(TRANSITION_MS);
  }

  function init() {
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    currentCards = Array.from(
      document.querySelectorAll<HTMLElement>('.case-card'),
    ).filter((card) => card.querySelector('.case-body'));

    currentCards.forEach((card) => {
      const header = card.querySelector<HTMLElement>('.case-header');
      if (!header) return;
      header.addEventListener(
        'click',
        (e) => {
          e.preventDefault();
          if (card.classList.contains('case-card--open')) {
            closeCard(card);
          } else {
            openCard(card);
          }
        },
        { signal },
      );
    });

    window.addEventListener(
      'case:open',
      (e) => {
        const slug = (e as CustomEvent<{ slug: string }>).detail?.slug;
        if (!slug) return;
        const card = document.getElementById(`case-${slug}`);
        if (!card) return;
        if (card.classList.contains('case-card--open')) {
          const r = card.getBoundingClientRect();
          smoothScrollTo(window.scrollY + r.top - 80);
          return;
        }
        if (currentCards.includes(card)) {
          openCard(card);
        } else {
          const r = card.getBoundingClientRect();
          smoothScrollTo(window.scrollY + r.top - 80);
        }
      },
      { signal },
    );

    // Auto-reopen the case the user just came from. Two sources, checked
    // in order: (1) URL hash like #case-cal, set by the in-page back link
    // on case detail pages; (2) document.referrer pointing at /work/[slug],
    // which covers the browser back button when no hash is present.
    const reopenFromContext = () => {
      let slug: string | null = null;

      const hash = window.location.hash;
      if (hash.startsWith('#case-')) {
        slug = hash.slice('#case-'.length);
      } else if (document.referrer) {
        try {
          const url = new URL(document.referrer);
          if (url.origin === window.location.origin) {
            const m = url.pathname.match(/^\/work\/([^/]+)\/?$/);
            if (m) slug = m[1];
          }
        } catch {
          /* malformed referrer — ignore */
        }
      }

      if (slug) {
        window.dispatchEvent(new CustomEvent('case:open', { detail: { slug } }));
      }
    };
    reopenFromContext();
  }

  document.addEventListener('astro:page-load', init);
</script>
