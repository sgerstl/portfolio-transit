---
const stops = [
  { line: 'CS1', target: 'epilog',   ziel: 'Epilog',   time: '4 min' },
  { line: 'CS1', target: 'cal',      ziel: 'Cal',      time: '3 min' },
  { line: 'CS1', target: 'racemake', ziel: 'Sim Racing Coach', time: '6 min' },
  { line: 'CS2', target: 'brightly', ziel: 'Brightly', time: '6 min' },
  { line: 'CS2', target: 'fleet',    ziel: 'Fleet',    time: '5 min' },
  { line: 'CS2', target: 'pqdr',     ziel: 'PQ + DR',  time: '4 min' },
  { line: 'P',   target: 'about',    ziel: 'About',    time: '2 min' },
  { line: 'P',   target: 'contact',  ziel: 'Contact',  time: '1 min' },
];
---

<aside class="naechste-station" aria-label="Upcoming case studies">
  <div class="ns-frame">
    <div class="ns-row ns-band ns-band--header">
      <span class="cell cell--line">Linie</span>
      <span class="cell cell--ziel">Ziel</span>
      <span class="cell cell--time">Lesezeit</span>
    </div>

    <div class="ns-led-area">
      <div class="ns-led">
        <div class="ns-led-inner">
          {stops.map((stop) => (
            <div class="ns-row ns-row--led" data-target={stop.target}>
              <span class="cell cell--line">{stop.line}</span>
              <span class="cell cell--ziel">{stop.ziel}</span>
              <span class="cell cell--time">{stop.time}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="ns-band ns-band--footer">
      <span class="footer-prefix">Current stop:</span>
      <span class="footer-station">Home</span>
    </div>
  </div>
</aside>

<script>
  const VISIBLE_ROWS = 5;
  const ROW_HEIGHT = 24;
  const CYCLE_MS = 5000;

  function init() {
    const ledInner = document.querySelector<HTMLElement>('.ns-led-inner');
    const ledRows = Array.from(document.querySelectorAll<HTMLElement>('.ns-row--led'));
    const board = document.querySelector<HTMLElement>('.naechste-station');
    const footerStation = document.querySelector<HTMLElement>('.ns-band--footer .footer-station');
    if (!ledInner || ledRows.length === 0 || !board) return;

    // Page-flip cycle: with 8 rows and 5 visible, two pages with 2-row
    // overlap. Page 0 = rows 1-5, page 1 = rows 4-8.
    const totalRows = ledRows.length;
    const pageOffsets =
      totalRows <= VISIBLE_ROWS
        ? [0]
        : [0, (totalRows - VISIBLE_ROWS) * ROW_HEIGHT];

    let pageIdx = 0;
    let paused = false;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const showPage = (i: number) => {
      ledInner.style.transform = `translateY(${-pageOffsets[i]}px)`;
    };
    showPage(0);

    if (pageOffsets.length > 1 && !reducedMotion) {
      setInterval(() => {
        if (paused) return;
        pageIdx = (pageIdx + 1) % pageOffsets.length;
        showPage(pageIdx);
      }, CYCLE_MS);
    }

    board.addEventListener('mouseenter', () => { paused = true; });
    board.addEventListener('mouseleave', () => { paused = false; });

    // Click → request the matching case (Accordion handles open-or-scroll)
    ledRows.forEach((row) => {
      row.addEventListener('click', () => {
        const slug = row.dataset.target;
        if (!slug) return;
        window.dispatchEvent(new CustomEvent('case:open', { detail: { slug } }));
      });
    });

    // Current-stop tracking — observe [data-case] elements; the most-
    // visible one wins. Reset to "Home" when scrolled near the top.
    if (footerStation) {
      const labels: Record<string, string> = {};
      ledRows.forEach((row) => {
        const slug = row.dataset.target;
        if (slug) labels[slug] = row.querySelector('.cell--ziel')?.textContent?.trim() ?? slug;
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const slug = (entry.target as HTMLElement).dataset.case;
            if (slug && labels[slug]) {
              footerStation.textContent = labels[slug];
            }
          });
        },
        { threshold: 0.4 },
      );
      document.querySelectorAll<HTMLElement>('[data-case]').forEach((el) => observer.observe(el));

      let ticking = false;
      window.addEventListener(
        'scroll',
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            if (window.scrollY < 100) footerStation.textContent = 'Home';
            ticking = false;
          });
        },
        { passive: true },
      );
    }

    // Hide board when content would overlap it. Compare each visible
    // [data-case] / .section-header right edge against the board's left
    // edge with an 8px buffer. rAF-throttle on scroll/resize/spine:redraw.
    const OVERLAP_BUFFER = 8;
    let overlapTicking = false;

    const checkOverlap = () => {
      const boardRect = board.getBoundingClientRect();
      if (boardRect.width === 0) return;
      const boardLeft = boardRect.left - OVERLAP_BUFFER;
      const boardTop = boardRect.top;
      const boardBottom = boardRect.bottom;

      const targets = document.querySelectorAll<HTMLElement>(
        '[data-case], .section-header',
      );
      let overlaps = false;
      for (const el of targets) {
        const r = el.getBoundingClientRect();
        if (r.bottom < boardTop || r.top > boardBottom) continue;
        if (r.right > boardLeft) {
          overlaps = true;
          break;
        }
      }
      board.classList.toggle('naechste-station--hidden', overlaps);
    };

    const scheduleOverlapCheck = () => {
      if (overlapTicking) return;
      overlapTicking = true;
      requestAnimationFrame(() => {
        checkOverlap();
        overlapTicking = false;
      });
    };

    checkOverlap();
    window.addEventListener('scroll', scheduleOverlapCheck, { passive: true });
    window.addEventListener('resize', scheduleOverlapCheck);
    window.addEventListener('spine:redraw', scheduleOverlapCheck);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .naechste-station {
    position: fixed;
    top: 73px;
    right: 13px;
    width: 380px;
    z-index: 50;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.20));
    user-select: none;
    transform: scale(0.9);
    transform-origin: top right;
    transition: opacity 0.25s ease;
  }

  .naechste-station--hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 1199px) {
    .naechste-station {
      display: none;
    }
  }

  .ns-frame {
    background: #616870;
    border: 1px solid #8E8E8E;
    border-radius: 5px;
    overflow: hidden;
  }

  .ns-row {
    display: grid;
    grid-template-columns: 48px 1fr 76px;
    align-items: center;
    gap: 10px;
    font-family: 'Barlow Condensed', sans-serif;
  }

  .ns-band { background: white; }

  .ns-band--header {
    height: 38px;
    padding: 0 50px;
    font-size: 19px;
    font-weight: 600;
    color: var(--color-text);
  }

  .ns-band--header .cell--time { text-align: right; }

  .ns-band--footer {
    height: 38px;
    padding: 0 50px;
    display: flex;
    align-items: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 19px;
    font-weight: 600;
    color: var(--color-text);
  }

  .ns-band--footer .footer-prefix {
    color: var(--color-text-soft);
    font-weight: 600;
    margin-right: 6px;
  }

  .ns-led-area {
    background: #616870;
    padding: 0 24px;
  }

  .ns-led {
    background: #171511;
    padding: 4px 12px;
    overflow: hidden;
    height: 128px;
  }

  .ns-led-inner {
    transition: transform 0.55s cubic-bezier(0.4, 0.0, 0.2, 1);
  }

  .ns-row--led {
    font-family: 'VT323', monospace;
    font-size: 22px;
    line-height: 1;
    color: #FFB000;
    text-shadow: 0 0 4px rgba(255, 176, 0, 0.45);
    cursor: pointer;
    transition: color 0.15s ease, text-shadow 0.15s ease;
    height: 24px;
    align-content: center;
  }

  .ns-row--led:hover {
    color: #FFD060;
    text-shadow: 0 0 6px rgba(255, 208, 96, 0.65);
  }

  .ns-row--led .cell--time { text-align: right; }
</style>
