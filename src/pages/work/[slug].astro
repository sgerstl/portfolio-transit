---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { CASES } from '../../data/cases';

export function getStaticPaths() {
  return CASES.filter((c) => c.body).map((c) => ({
    params: { slug: c.slug },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const colorVar = `var(--color-line-${entry.line})`;
---

<Layout title={`${entry.name} — Scott Gerstl`}>
  <Header />

  <main class="case-page" style={`--accent: ${colorVar};`}>
    <a class="back" href="/#cases">← Back to cases</a>

    <header class="case-page-head">
      <h1>{entry.name}</h1>
      <p class="lede">{entry.tagline}</p>
    </header>

    {entry.body && (
      <section class="case-page-body">
        <div class="domains">
          {entry.body.domains.map((d) => <span>{d}</span>)}
        </div>
        <p class="outcome">{entry.body.outcome}</p>
        <p class="claim">{entry.body.claim}</p>
        <p class="placeholder">Full case study coming soon.</p>
      </section>
    )}
  </main>
</Layout>

<style>
  .case-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 32px 120px;
  }

  .back {
    /* Sticks just below the 60px sticky header (with breathing). */
    position: sticky;
    top: 80px;
    z-index: 50;
    display: inline-block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    text-decoration: none;
    margin-bottom: 28px;
    padding: 6px 12px;
    background: rgba(246, 246, 246, 0.78);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  .back:hover {
    color: var(--accent);
  }

  .case-page-head h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 64px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: 12px;
    border-left: 6px solid var(--accent);
    padding-left: 18px;
  }

  .lede {
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    line-height: 1.45;
    color: var(--color-text);
    padding-left: 24px;
    margin-bottom: 40px;
  }

  .domains {
    background: #FFCC00;
    padding: 6px 16px;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 12px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 28px;
  }

  .domains span:not(:last-child)::after {
    content: '·';
    margin-left: 12px;
    opacity: 0.6;
  }

  .outcome,
  .claim {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 22px;
  }

  .claim {
    font-weight: 600;
  }

  .placeholder {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: var(--color-text-soft);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-top: 24px;
    margin-top: 32px;
  }
</style>
