---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const RESUME_PAGES = ['/images/resume/page-1.png', '/images/resume/page-2.png'];
---

<Layout title="Resume | Scott Gerstl">
  <Header />

  <main class="resume-page">
    <a class="back" href="/">← Back to home</a>

    <header class="resume-head">
      <h1>Resume</h1>
      <p class="lede">Senior product designer. Berlin. Enterprise platforms and AI products.</p>
    </header>

    <div class="actions">
      <a class="download-btn" href="/resume.pdf" download="Scott Gerstl Resume.pdf">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download PDF
      </a>
      <a class="open-btn" href="/resume.pdf" target="_blank" rel="noopener noreferrer">
        Open in new tab ↗
      </a>
    </div>

    <div class="pdf-pages">
      {RESUME_PAGES.map((src, i) => (
        <div class="pdf-page">
          <img src={src} alt={`Scott Gerstl Resume | Page ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .resume-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 120px 32px 120px;
  }

  .back {
    position: fixed;
    top: 80px;
    left: 32px;
    z-index: 50;
    display: inline-block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    text-decoration: none;
    padding: 6px 12px;
    background: rgba(246, 246, 246, 0.78);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 4px;
  }

  .back:hover {
    color: var(--color-rail-blue);
  }

  .resume-head {
    margin-bottom: 24px;
  }

  .resume-head h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 64px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: 12px;
    border-left: 6px solid var(--color-rail-blue);
    padding-left: 18px;
  }

  .lede {
    font-family: 'Inter', sans-serif;
    font-size: 19px;
    line-height: 1.5;
    color: var(--color-text);
    padding-left: 24px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
    padding-left: 24px;
  }

  .download-btn,
  .open-btn {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .download-btn {
    background: var(--color-text);
    color: white;
    border: 1px solid var(--color-text);
  }

  .download-btn:hover {
    background: #2a2a2a;
    border-color: #2a2a2a;
  }

  .open-btn {
    background: white;
    color: var(--color-text);
    border: 1px solid rgba(0, 0, 0, 0.18);
  }

  .open-btn:hover {
    border-color: var(--color-text);
  }

  .pdf-pages {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pdf-page {
    background: white;
    border-radius: 4px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      0 8px 24px rgba(0, 0, 0, 0.10),
      0 24px 56px rgba(0, 0, 0, 0.12);
  }

  .pdf-page img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 767px) {
    .resume-page {
      padding: 116px 16px 80px;
    }

    .back {
      left: 16px;
    }

    .resume-head h1 {
      font-size: 42px;
      padding-left: 14px;
      border-left-width: 5px;
    }

    .lede {
      font-size: 16px;
      padding-left: 19px;
    }

    .actions {
      padding-left: 19px;
    }

    .pdf-pages {
      gap: 12px;
    }
  }
</style>
