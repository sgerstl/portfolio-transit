---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import MapWallpaper from '../components/MapWallpaper.astro';
import DepartureBoard from '../components/DepartureBoard.astro';
import Hero from '../components/hero/Hero.tsx';
---

<Layout title="Scott Gerstl — Portfolio">
  <Header />
  <DepartureBoard />

  <div class="page">
    <MapWallpaper />
    <Hero client:load />

    <div id="cases" class="page-spacer">
      <p class="page-spacer__note">Cases land here next session.</p>
    </div>
  </div>
</Layout>

<style>
  .page-spacer {
    min-height: 220vh;
    padding-top: calc(100vh + 320px);
    padding-left: 200px;
    color: var(--color-text-soft);
  }
  .page-spacer__note {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
