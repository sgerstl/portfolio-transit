---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import ContactFab from '../components/ContactFab.astro';

interface Props {
  title?: string;
}

const { title = 'Scott Gerstl | Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=VT323&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta property="og:title" content="Scott Gerstl — Senior product designer" />
    <meta property="og:description" content="15 years shipping enterprise platforms and AI products. Berlin." />
    <meta property="og:image" content="https://ux.scottgerstl.com/og-image.png" />
    <meta property="og:url" content="https://ux.scottgerstl.com/" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://ux.scottgerstl.com/og-image.png" />
    <meta name="twitter:title" content="Scott Gerstl — Senior product designer" />
    <meta name="twitter:description" content="15 years shipping enterprise platforms and AI products. Berlin." />
    <ClientRouter />
    <script>
      document.addEventListener('contextmenu', (e) => {
        const target = e.target as HTMLElement | null;
        if (target?.tagName === 'IMG' && !target.hasAttribute('data-allow-save')) {
          e.preventDefault();
        }
      });
    </script>
  </head>
  <body>
    <slot />
    <ContactFab />
  </body>
</html>
